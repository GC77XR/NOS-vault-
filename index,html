<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>V-077XR // TEST PHASE</title>
    <style>
        :root {
            --glow: 0.2;
            --purple: #bc13fe;
            --bg-color: #0d001a; /* SATA Indigo Start */
        }

        body {
            margin: 0; 
            background-color: var(--bg-color); 
            color: #fff;
            font-family: 'Courier New', monospace;
            display: flex; justify-content: center; align-items: center;
            height: 100vh; overflow: hidden;
            transition: background-color 30s linear; /* Smooth shift to Gold */
        }

        .gold-state { --bg-color: #4d3300; } /* CODA Gold End */

        #boot-screen, #vessel { text-align: center; width: 100%; }
        
        /* High-visibility Gold Button */
        .gold-btn {
            background: transparent; border: 2px solid #ffd700; color: #ffd700;
            padding: 20px 40px; cursor: pointer; font-family: inherit;
            font-weight: bold; font-size: 1.2rem; transition: 0.5s;
        }
        .gold-btn:hover { background: #ffd700; color: #000; }

        #re-enter { 
            opacity: 0; visibility: hidden; transition: opacity 3s ease; 
            color: #4af2a1; border-color: #4af2a1;
        }
        .visible { opacity: 1 !important; visibility: visible !important; }

        /* Anchor Logo Ghostly Trace */
        #anchor-logo {
            max-width: 300px;
            transition: opacity 10s ease;
            filter: drop-shadow(0 0 15px var(--purple));
        }
        .ghostly { opacity: 0.05; }

        #timestamp { font-size: 1.5rem; margin-top: 20px; font-weight: bold; }
        .hidden { display: none !important; }
    </style>
</head>
